# Продакшн-переменные UOTP. Скопировать в .env.prod и заполнить.
# Секреты не коммитить. Пароли и ключи сгенерировать заново.

APP_ENV=demo
API_HOST=0.0.0.0
API_PORT=8000

# Домены (A-записи должны указывать на IP виртуалки).
DOMAIN=uotp.integro.kz
FILES_DOMAIN=files.uotp.integro.kz
ACME_EMAIL=admin@integro.kz
CORS_ORIGINS=https://uotp.integro.kz

# База данных.
POSTGRES_USER=uotp
POSTGRES_PASSWORD=ЗАМЕНИТЬ_НА_СИЛЬНЫЙ_ПАРОЛЬ
POSTGRES_DB=uotp
DATABASE_URL=postgresql+asyncpg://uotp:ЗАМЕНИТЬ_НА_СИЛЬНЫЙ_ПАРОЛЬ@db:5432/uotp

# Redis.
REDIS_URL=redis://redis:6379/0

# Файловое хранилище (публичный адрес = FILES_DOMAIN через Caddy).
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=https://files.uotp.integro.kz
MINIO_ROOT_USER=uotp_minio
MINIO_ROOT_PASSWORD=ЗАМЕНИТЬ_НА_СИЛЬНЫЙ_ПАРОЛЬ
MINIO_BUCKET=uotp-files
MINIO_SECURE=false

# JWT (сгенерировать: openssl rand -hex 32).
JWT_SECRET=ЗАМЕНИТЬ_НА_32_БАЙТА_HEX
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# Голосовой модуль (OpenAI). Пусто = выключен, эндпоинт вернёт 503.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
OPENAI_PARSE_MODEL=gpt-4o-mini
